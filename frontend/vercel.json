{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://tagwraps-sec.onrender.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://tagwraps-sec.onrender.com/health"
    },
    {
      "source": "/health/",
      "destination": "https://tagwraps-sec.onrender.com/health"
    },
    {
      "source": "/health/:path*",
      "destination": "https://tagwraps-sec.onrender.com/health/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}

